# Server
SERVER_ADDR=:8080
GIN_MODE=release
SHUTDOWN_TIMEOUT_SEC=5

# MySQL (required)
# Example:
# MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/quiz_db?charset=utf8mb4&parseTime=True&loc=Local
MYSQL_DSN=
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=100
DB_CONN_MAX_LIFETIME_MIN=60

# Redis
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=replace_with_your_secret
JWT_EXPIRE_HOURS=24

